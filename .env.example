# ══════════════════════════════════════════════════════════════════════════════
# DiscountFlow — Environment Variables Reference
#
# Copy this file:  cp .env.example .env
# Fill in values,  then run: shopify app dev
#
# NEVER commit .env — it contains secrets and is excluded by .gitignore.
# This file (.env.example) IS committed — it documents required variables
# with format examples but no real values.
#
# Variables are split into three groups:
#   LOCAL   → your .env file (used by `shopify app dev`)
#   VERCEL  → Vercel dashboard → Project → Settings → Environment Variables
#   SHOPIFY → Partner Dashboard / shopify.app.toml (NOT env vars)
# ══════════════════════════════════════════════════════════════════════════════


# ── SHOPIFY APP CREDENTIALS ────────────────────────────────────────────────────
# Source: Partner Dashboard → Apps → [your app] → Configuration → API credentials
#
# During `shopify app dev`, the Shopify CLI injects these automatically from the
# linked app. You still need them here if you ever run `npm run dev` standalone.
#
# LOCAL:   copy from Partner Dashboard
# VERCEL:  add both to Vercel → Environment Variables

# 32-character hexadecimal string
SHOPIFY_API_KEY=

# Starts with "shpss_" followed by a long hex string
SHOPIFY_API_SECRET=


# ── APP URL ────────────────────────────────────────────────────────────────────
# The public HTTPS URL where the app is hosted.
# Used to build OAuth callback URLs, webhook endpoints, and App Bridge config.
#
# LOCAL:      `shopify app dev` auto-injects this via a Cloudflare tunnel.
#             Format: https://<random-hash>.trycloudflare.com
#             You do NOT need to set it manually when using the CLI.
#
# VERCEL:     Your permanent Vercel deployment URL (does not change between deploys).
#             Update shopify.app.toml → application_url to match, then run
#             `shopify app deploy` to sync with the Partner Dashboard.
#             Format: https://your-project-name.vercel.app

SHOPIFY_APP_URL=https://your-project-name.vercel.app


# ── OAUTH SCOPES ───────────────────────────────────────────────────────────────
# Comma-separated list of Shopify API access scopes requested during OAuth.
# Must exactly match `[access_scopes].scopes` in shopify.app.toml.
#
# During `shopify app dev`, the CLI reads scopes from shopify.app.toml.
# The code in shopify.server.ts also reads this env var directly, so keep
# both in sync.
#
# LOCAL:   set to the same value as shopify.app.toml
# VERCEL:  set to the same value

SCOPES=read_products,write_products,read_orders,read_discounts,write_discounts


# ── NEON POSTGRESQL ────────────────────────────────────────────────────────────
# Source: Neon Dashboard → your project → Connection Details (top-right)
#
# Neon provides TWO endpoints for the same database:
#
#   Pooled   (DATABASE_URL)  → hostname contains "-pooler"
#                              Uses PgBouncer. Safe for serverless (Vercel).
#                              Used by the app at runtime for all queries.
#
#   Direct   (DIRECT_URL)    → hostname does NOT contain "-pooler"
#                              Bypasses PgBouncer. Required by Prisma Migrate
#                              because it uses the extended query protocol.
#                              Used only during `prisma migrate deploy` (build step).
#
# LOCAL:   Can use the same Neon project. Recommended: create a "dev" branch
#          in Neon (free, instant) so local migrations don't touch production.
#
# VERCEL:  Use the "main" branch connection strings (production database).
#          DIRECT_URL must be set so `prisma migrate deploy` works in the
#          Vercel build step (runs inside `npm run setup`).

# Pooled connection — app runtime queries (serverless-safe)
# Format: postgres://user:password@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL=

# Direct connection — prisma migrate only
# Format: postgres://user:password@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require
DIRECT_URL=


# ── CRON SECRET ────────────────────────────────────────────────────────────────
# Used in Phase 2 to authenticate requests to /api/cron/sync-campaigns.
# Vercel injects this automatically into cron job requests as:
#   Authorization: Bearer <CRON_SECRET>
# Your cron handler validates this header before processing.
#
# Generate a value now (you'll need it when implementing the cron handler):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# LOCAL:   optional during development (cron is not triggered locally)
# VERCEL:  required — add to Vercel → Environment Variables

CRON_SECRET=


# ── RUNTIME ────────────────────────────────────────────────────────────────────
# Vercel sets NODE_ENV=production automatically.
# Setting it explicitly here ensures no ambiguity if running the built app
# locally with `npm run start`.
#
# LOCAL:   omit (defaults to "development", managed by the CLI)
# VERCEL:  set to "production"

# NODE_ENV=production


# ── OPTIONAL / ADVANCED ───────────────────────────────────────────────────────
# Restrict this app to only accept OAuth from one specific shop.
# Useful when testing with a single dev store in isolation.
# Leave commented-out for a public multi-tenant app.
#
# Format: your-store.myshopify.com  (no https://, no trailing slash)

# SHOP_CUSTOM_DOMAIN=
